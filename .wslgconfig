# WSL 2 Global Configuration
# This file applies to all WSL 2 distros

[wsl2]
# Allocate resources for development work
memory=24GB
processors=12
swap=6GB
swapfile=C:\\temp\\wsl-swap.vhdx

# VM tuning
localhostforwarding=true
nestedVirtualization=false

# Debugging
debugConsole=false

[experimental]
sparseVhd=true
autoMemoryReclaim=gradual
